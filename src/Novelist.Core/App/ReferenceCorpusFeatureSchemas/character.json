{
  "schema_id": "reference-corpus.feature.character.v1",
  "schema_version": "reference-corpus-feature-family-v1",
  "family": "character",
  "node_type": "passage",
  "max_observations": 8,
  "required_observation_fields": ["feature_key", "power_position", "desire_exposure", "relationship_tension", "confidence", "evidence_start", "evidence_end", "explanation"],
  "observation_fields": {
    "feature_key": { "type": "enum", "enum": ["dynamics"] },
    "power_position": { "type": "enum", "enum": ["dominant", "pressured", "equal", "shifting"] },
    "desire_exposure": { "type": "enum", "enum": ["hidden", "implied", "explicit", "denied"] },
    "relationship_tension": { "type": "enum", "enum": ["low", "medium", "high", "explosive"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 0.95 },
    "evidence_start": { "type": "integer", "minimum": 0 },
    "evidence_end": { "type": "integer", "minimum": 1 },
    "explanation": { "type": "string", "max_length": 360 }
  }
}
