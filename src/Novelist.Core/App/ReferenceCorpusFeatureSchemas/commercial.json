{
  "schema_id": "reference-corpus.feature.commercial.v1",
  "schema_version": "reference-corpus-feature-family-v1",
  "family": "commercial",
  "node_type": "passage",
  "max_observations": 8,
  "required_observation_fields": ["feature_key", "hook_type", "payoff_density", "expectation_management", "confidence", "evidence_start", "evidence_end", "explanation"],
  "observation_fields": {
    "feature_key": { "type": "enum", "enum": ["mechanics"] },
    "hook_type": { "type": "enum", "enum": ["question", "threat", "reveal", "reversal", "promise", "cliffhanger"] },
    "payoff_density": { "type": "enum", "enum": ["none", "low", "medium", "high"] },
    "expectation_management": { "type": "enum", "enum": ["setup", "delay", "satisfy", "subvert", "escalate"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 0.95 },
    "evidence_start": { "type": "integer", "minimum": 0 },
    "evidence_end": { "type": "integer", "minimum": 1 },
    "explanation": { "type": "string", "max_length": 360 }
  }
}
