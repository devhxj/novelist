{
  "schema_id": "reference-corpus.feature.sensory.v1",
  "schema_version": "reference-corpus-feature-family-v1",
  "family": "sensory",
  "node_type": "sentence",
  "max_observations": 12,
  "required_observation_fields": ["feature_key", "sense", "intensity", "narrative_function", "confidence", "evidence_start", "evidence_end", "explanation"],
  "observation_fields": {
    "feature_key": { "type": "enum", "enum": ["sensory_detail"] },
    "sense": { "type": "enum", "enum": ["visual", "auditory", "tactile", "temperature", "smell", "taste", "kinesthetic"] },
    "intensity": { "type": "number", "minimum": 0, "maximum": 10 },
    "narrative_function": { "type": "enum", "enum": ["anchor_scene", "raise_tension", "reveal_state", "slow_pace", "accelerate_pace"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 0.95 },
    "evidence_start": { "type": "integer", "minimum": 0 },
    "evidence_end": { "type": "integer", "minimum": 1 },
    "explanation": { "type": "string", "max_length": 360 }
  }
}
