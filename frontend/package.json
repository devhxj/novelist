{
  "name": "novelist-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:reference-anchor": "npm run test:reference-workspace",
    "test:reference-style": "npm run test:reference-workspace",
    "test:reference-style:stress": "npm run test:reference-workspace",
    "test:chapter-range": "node tests/chapter-range.test.mjs",
    "test:time": "node tests/time.test.mjs",
    "test:layout": "node tests/layout.test.mjs",
    "test:diagnostics": "node tests/diagnostics.test.mjs",
    "test:layout-ui": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --grep=@layout",
    "test:pattern": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --grep=@pattern",
    "test:git": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --grep=@git",
    "test:relative-time": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --grep=@time",
    "test:update": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --grep=@update",
    "test:error-ui": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --grep=@error",
    "test:corpus-library": "npm run test:reference-workspace",
    "test:reference-workspace": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --grep=@reference-workspace",
    "test:chapter-reference": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase16 --grep=@chapter-reference",
    "test:phase16": "npm run test:reference-workspace && npm run test:chapter-reference",
    "test:phase15": "node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@phase15-surface && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@phase15-stress && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@phase15-compact && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@reference-anchor && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@pattern && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@git && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@layout && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@time && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@update && node scripts/app-mock-workflow.mjs --suite=full --target=vite --phase=phase15 --grep=@error",
    "test:app": "node scripts/app-mock-workflow.mjs --suite=smoke --target=vite",
    "test:app:full": "node scripts/app-mock-workflow.mjs --suite=full --target=vite",
    "test:app:stress": "node scripts/app-mock-workflow.mjs --suite=stress --target=vite",
    "test:app:usability": "node scripts/app-mock-workflow.mjs --suite=usability --target=vite",
    "test:app:dist": "node scripts/app-mock-workflow.mjs --suite=smoke --target=dist",
    "verify": "npm run build && npm run lint && npm run test:phase16 && npm run test:app"
  },
  "dependencies": {
    "@antv/g6": "^5.1.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.8.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@csstools/postcss-oklab-function": "^5.0.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
