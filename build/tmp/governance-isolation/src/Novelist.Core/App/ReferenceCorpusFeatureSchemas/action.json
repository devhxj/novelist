{
  "schema_id": "reference-corpus.feature.action.v1",
  "schema_version": "reference-corpus-feature-family-v1",
  "family": "action",
  "node_type": "passage",
  "max_observations": 8,
  "required_observation_fields": ["feature_key", "granularity", "chain_structure", "character_reveal", "confidence", "evidence_start", "evidence_end", "explanation"],
  "observation_fields": {
    "feature_key": { "type": "enum", "enum": ["action_chain"] },
    "granularity": { "type": "enum", "enum": ["micro", "medium", "broad"] },
    "chain_structure": { "type": "enum", "enum": ["single_beat", "escalation", "interruption", "cause_effect", "reaction_loop"] },
    "character_reveal": { "type": "enum", "enum": ["restraint", "decisiveness", "hesitation", "aggression", "vulnerability"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 0.95 },
    "evidence_start": { "type": "integer", "minimum": 0 },
    "evidence_end": { "type": "integer", "minimum": 1 },
    "explanation": { "type": "string", "max_length": 360 }
  }
}
