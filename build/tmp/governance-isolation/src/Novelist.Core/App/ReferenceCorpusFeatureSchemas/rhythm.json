{
  "schema_id": "reference-corpus.feature.rhythm.v1",
  "schema_version": "reference-corpus-feature-family-v1",
  "family": "rhythm",
  "node_type": "sentence",
  "max_observations": 8,
  "required_observation_fields": ["feature_key", "label", "char_count", "cadence", "confidence", "evidence_start", "evidence_end", "explanation"],
  "observation_fields": {
    "feature_key": { "type": "enum", "enum": ["length_band", "cadence", "pause_density", "ending_weight"] },
    "label": { "type": "enum", "enum": ["short", "medium", "long", "staccato", "flowing", "accelerating", "decelerating", "light_tail", "heavy_tail"] },
    "char_count": { "type": "integer", "minimum": 1, "maximum": 240 },
    "cadence": { "type": "enum", "enum": ["staccato", "flowing", "accelerating", "decelerating", "steady"] },
    "pause_density": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 0.95 },
    "evidence_start": { "type": "integer", "minimum": 0 },
    "evidence_end": { "type": "integer", "minimum": 1 },
    "explanation": { "type": "string", "max_length": 360 }
  }
}
