{
  "schema_id": "reference-corpus.feature.emotion.v1",
  "schema_version": "reference-corpus-feature-family-v1",
  "family": "emotion",
  "node_type": "sentence",
  "max_observations": 8,
  "required_observation_fields": ["feature_key", "surface", "subtext", "direction", "mode", "intensity", "confidence", "evidence_start", "evidence_end", "explanation"],
  "observation_fields": {
    "feature_key": { "type": "enum", "enum": ["emotion_state"] },
    "surface": { "type": "enum", "enum": ["calm", "anger", "fear", "relief", "desire", "shame", "numb", "grief"] },
    "subtext": { "type": "enum", "enum": ["restrained", "denied", "displaced", "escalating", "masking"] },
    "direction": { "type": "enum", "enum": ["rising", "falling", "stable", "reversal"] },
    "mode": { "type": "enum", "enum": ["suppressed", "eruptive", "indirect", "direct", "blank"] },
    "intensity": { "type": "number", "minimum": 0, "maximum": 10 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 0.95 },
    "evidence_start": { "type": "integer", "minimum": 0 },
    "evidence_end": { "type": "integer", "minimum": 1 },
    "explanation": { "type": "string", "max_length": 360 }
  }
}
