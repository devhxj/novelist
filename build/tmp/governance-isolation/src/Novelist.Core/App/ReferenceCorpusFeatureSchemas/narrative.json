{
  "schema_id": "reference-corpus.feature.narrative.v1",
  "schema_version": "reference-corpus-feature-family-v1",
  "family": "narrative",
  "node_type": "passage",
  "max_observations": 8,
  "required_observation_fields": ["feature_key", "function", "confidence", "evidence_start", "evidence_end", "explanation"],
  "observation_fields": {
    "feature_key": { "type": "enum", "enum": ["narrative_function"] },
    "function": { "type": "enum", "enum": ["advance_plot", "reveal_information", "withhold_answer", "establish_atmosphere", "transition", "foreshadow", "payoff", "reversal"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 0.95 },
    "evidence_start": { "type": "integer", "minimum": 0 },
    "evidence_end": { "type": "integer", "minimum": 1 },
    "explanation": { "type": "string", "max_length": 360 }
  }
}
